# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# MongoDB Connection String (Atlas recommended)
MONGO_URI="mongodb+srv://<user>:<password>@cluster0.mongodb.net/climora?retryWrites=true&w=majority"

# JWT Secret for authentication
JWT_SECRET="your_very_secure_jwt_secret_key"

# WAQI (World Air Quality Index) API Key
WAQI_API_KEY="your_waqi_api_key_here"

# OpenWeatherMap API Key
OPENWEATHER_API_KEY="your_openweather_api_key_here"
